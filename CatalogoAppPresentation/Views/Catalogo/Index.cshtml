@model List<CatalogoApp.Domain.Models.Item>
 
<h1>Catálogo de Videojuegos</h1>
 
<!-- Filtro por Genero -->
<div class="mb-4">
    <div class="btn-group" role="group" aria-label="Filtro por géneros">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Todos</a>
        @foreach (var gen in (ViewBag.Generos as List<string>) ?? new List<string>())
        {
            <a asp-action="Index" asp-route-genero="@gen" class="btn btn-outline-secondary btn-sm">@gen</a>
        }
    </div>
</div>

<hr />

<!-- Lista de Items -->
<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    @foreach (var item in Model)
    {
        <div class="col">
            <div class="card h-100 shadow-sm transition-hover">
                <a asp-action="Detalle" asp-route-id="@item.Id" style="text-decoration: none; color: inherit;">
                    <div class="card-body">
                        <h5 class="card-title">@item.Titulo</h5>
                        <h6 class="card-subtitle mb-2 text-muted">@item.Genero</h6>
                        <p class="card-text text-truncate">@item.Descripcion</p>
                    </div>
                    <div class="card-footer bg-transparent border-top-0 d-flex justify-content-between align-items-center">
                        <small class="text-muted"><i class="bi bi-calendar"></i> @item.Ano</small>
                        <span class="badge bg-primary rounded-pill">Ver detalles</span>
                    </div>
                </a>
            </div>
        </div>
    }
</div>

<hr class="mt-5" />
<div class="text-center mb-4">
    <a asp-action="Agregar" class="btn btn-primary btn-lg px-5 rounded-pill shadow-sm">
        <i class="bi bi-plus-circle me-2"></i>Agregar videojuego
    </a>
</div>